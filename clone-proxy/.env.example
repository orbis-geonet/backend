# ══════════════════════════════════════════════════════════════
#  ORBIS CLONE PROXY — configuration
# ══════════════════════════════════════════════════════════════

# ─── Solana / on-chain ───
RPC_URL='https://api.devent-beta.solana.com'
PROGRAM_ID=x2HARL2kBx2jVHtgWvf8sX8zbZ3sBAvtHJeg8AgosqR
MERKLE_TREE_MINT='GHT8s6m5gw2jSyJVmyH1Zcx4RbqnVapAmuRZJNyqe8Qg'
ORBIS_MINT=GBGPmQ6Mxz8FBxFvQwfBTdJYejDUP9G8auZfDnTwPm9
WALLET_PATH=wallet.json

# ─── This node ───
CLONE_PORT=3110
CLONE_BASE_URL=https://your-node-name.orbis.network

# ─── Backends ───
LOCAL_MONGO_URI=mongodb://localhost:27017
LOCAL_DB_NAME=orbisv2production
JAVA_BACKEND_URL=https://orbisv2-production.uc.r.appspot.com

# ─── Secrets / auth ───
API_SECRET="my-super-strong-secret-key123"
ORBIS_API_SECRET="my-internal-master-key456"

# ─── Manifest producer: flush lanes ───
# A lane commits an on-chain manifest when queued entries reach COUNT
# OR the oldest queued change reaches AGE. On-chain tx size is constant
# regardless of entry count, so AGE controls how often you push and
# COUNT is only an early-flush cap for big bursts.
PUBLIC_FLUSH_COUNT=200
PUBLIC_FLUSH_AGE_MS=120000
DERIVED_FLUSH_COUNT=500
DERIVED_FLUSH_AGE_MS=600000
MANIFEST_FLUSH_TICK_MS=15000

# ─── Consumer ───
# Eagerly fetch+pay each committed manifest's payload (full local mirror) vs lazy per-request.
AUTO_FETCH_EVENTS=false
# Let a single node consume its own manifests (single-machine smoke test).
SELF_CONSUME=false

# ─── Runtime toggles ───
DISABLE_BATCH=false
REGISTER=false
SKIP_HISTORY=false
DRY_RUN=false
NO_CACHE=false
OVERRIDE=false
MONGO_WATCH_RESTART_MS=30000

# ─── Tribe payments (crypto, optional) ───
# Set DEVNET_RPC_URL + DEVNET_PAYMENTS_PROGRAM_ID to enable pay_tribe (routes/payments.ts).
# Treasury + ORBIS mint are read from on-chain GlobalConfig, so they are NOT set here.
DEVNET_RPC_URL=https://api.devnet.solana.com
DEVNET_PAYMENTS_PROGRAM_ID=GHT8s6m5gw2jSyJVmyH1Zcx4RbqnVapAmuRZJNyqe8Qg
# Fixed USD price of 1 ORBIS (no oracle). e.g. 0.05 => 1 ORBIS = $0.05.
ORBIS_USD_PRICE=0.05
# Optional wallet that receives the clone operator's 7% cut. Defaults to the clone
# operator's own wallet. Set ONLY if that wallet would otherwise equal the treasury.
CLONE_PAYOUT_WALLET=
