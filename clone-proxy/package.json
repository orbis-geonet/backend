  "description": "Orbis Protocol Clone Proxy Service",
  "main": "index.ts",
  "type": "module",
  "scripts": {
    "prestart": "tsx scripts/initialize-program.ts",
    "start": "tsx index.ts",
    "dev": "tsx watch index.ts",
