    "body-parser": "^1.20.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "mongodb": "^7.1.0",
    "reflect-metadata": "^0.2.2",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
